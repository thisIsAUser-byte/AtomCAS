    //these constructors serve as various ways to build the number from structure of the inputs.
    public LargeInteger(long num){
        number = new ArrayList<>();
        do{
            number.addFirst(num % 1000000000L);
            num /= 1000000000L;
        }while(num != 0L);
        sign = number.getFirst() < 0;
        number.replaceAll(Math::abs);
    }
    private LargeInteger(ArrayList<Long> digits, long sign){
        number = new ArrayList<>();
        number.addAll(digits);
        if(number.isEmpty()){
            number.add(0L);
            this.sign = false;
            return;
        }
        for(int i = number.size()-1; i > 0; i--){
            number.set(i-1, number.get(i-1) + number.get(i)/1000000000L);
            number.set(i, number.get(i)%1000000000L);
        }
        number.replaceAll(Math::abs);
        while(number.size() > 1 && number.getFirst() == 0L) number.removeFirst();
        if(number.size() != 1 || number.getFirst() != 0L)
            this.sign = sign == -1;
        else this.sign = false;
        number.replaceAll(Math::abs);
    }
    public LargeInteger(String str){
        ArrayList<Long> ar = new ArrayList<>();
        if(str.isEmpty()){
            ar.add(0L);
            sign = false;
            number = ar;
            return;
        }
        if(str.contains("+") || str.contains("-") || str.contains("*") || str.contains("/")){
            LargeFraction f = new LargeFraction(str);
            LargeInteger C = f.numerator.longDivision(f.denominator);
            sign = C.sign;
            number = C.number;
            return;
        }else if (!str.matches("-?\\d+")) throw new IllegalArgumentException("Invalid input: " + str);
        //eliminate leading zeros to avoid ambiguity
        while(str.length() > 1 && str.charAt(0) == '0') str = str.substring(1);
        for(int j = str.length(); j > 0; j-=9){
            if(str.charAt(0) != '-' && j <= 9){
                ar.addFirst(Long.parseLong(str.substring(0, j)));
                break;
            }else
                ar.addFirst(Long.parseLong(str.substring(j-9, j)));
        }
        sign = str.charAt(0) == '-';
        number = ar;
    }
