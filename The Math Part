        if (sign) str.append("-");
        for (long i = 0; i < range; i++) str.append(RNG.nextLong(10L));
        boolean point = RNG.nextBoolean();
        if (point) {
            str.append(".");
            //nonrepeating part
            long range2 = RNG.nextLong(50L) + 1;
            for (long i = 0; i < range2; i++) str.append(RNG.nextLong(10L));
