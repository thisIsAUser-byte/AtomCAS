                for(int i = copy.number.size()-1; i >= 0; i--){
                    part += copy.number.get(i) + copy2.number.get(i);
                    sum.addFirst(part % 1000000000L);
                    part /= 1000000000L;
                }
                while(part > 0){
                    sum.addFirst(part % 1000000000L);
                    part /= 1000000000L;
                }
