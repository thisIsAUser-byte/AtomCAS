            result.number.set(i, result.number.get(i)*Math.abs(greg) + carry);
            carry = result.number.get(i)/1000000000L;
            result.number.set(i, result.number.get(i)%1000000000L);
        }
        while(carry > 0){
            result.number.addFirst(carry%1000000000L);
            carry = carry/1000000000L;
        }
