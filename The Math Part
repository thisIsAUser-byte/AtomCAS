    public LargeList<PrimeExponent> factor() {
        LargeList<PrimeExponent> n = numerator.factor();
        LargeList<PrimeExponent> d = denominator.factor();
        for (PrimeExponent p : d)
            n.add(new PrimeExponent(p.base, (LargeFraction) p.exponent.multiply(LargeFraction.negativeOne)));
        while (n.size().greaterThan(LargeInteger.one) && n.getFirst().base.equalsTo(LargeInteger.one)) n.removeFirst();
        while (n.size().greaterThan(LargeInteger.one) && n.getLast().base.equalsTo(LargeInteger.one)) n.removeLast();
        PrimeExponent.sortBases(n);
        if (n.getFirst().base.equalsTo(LargeInteger.one)) n.getFirst().exponent = LargeFraction.one;
        return n;
    }
    public static LargeFraction buildFromFactors(LargeList<PrimeExponent> pr) {
        LargeFraction result = LargeFraction.one;
        for (PrimeExponent p : pr) {
            if (p.exponent.denominator.notEqualsTo(LargeInteger.one))
                throw new IllegalStateException("Error: Not a rational number");
            LargeInteger expTemp = p.exponent.numerator;
            LargeInteger basTemp = p.base.copy();
            while(expTemp.notEqualsTo(LargeInteger.zero)) {
                if (expTemp.isOdd()) {
                    if (expTemp.sign().equalsTo(LargeInteger.negativeOne)) result = (LargeFraction) result.divide(basTemp);
                    else result = (LargeFraction) result.multiply(basTemp);
                    if(expTemp.magnitude().equals(LargeInteger.one)) break;
                }
                basTemp = basTemp.square();
                expTemp = expTemp.longDivision(LargeInteger.two);
            }
        }
        return result;
    }
