                            part -= 1;
                        }else if(finalSign == -1 && sum.getFirst() > 0){
                            sum.set(0, Math.floorMod(-sum.getFirst(), 1000000000L));
                            part /= 1000000000L;
                            part += 1;
                        }else part /= 1000000000L;
                    }else part /= 1000000000L;
