            LargeInteger z0 = (LargeInteger) copy.multiply(copy2);
            LargeInteger z2 = (LargeInteger) breakIt.multiply(breakIt2);
            LargeInteger z1 = (LargeInteger) breakIt.add(copy).multiply(breakIt2.add(copy2));
