                long rem = 0L;
                long absM = ((LargeInteger) other).number.getFirst();
                for (long chunk : number)
                    rem = (rem * 1000000000L + chunk) % absM;
                if (this.sign && rem != 0L)
                    rem = absM - rem;
                if (((LargeInteger) other).sign && rem != 0L)
                    rem = rem - absM;
                return new LargeInteger(rem);
            }
            return this.subtract(this.floorDivision((LargeInteger) other).multiply(other));
