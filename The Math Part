    public LargeFraction longSqrt(){
        if(this.equalsTo(zero)) return LargeFraction.zero;
        LargeFraction result = LargeFraction.one;
        LargeList<PrimeExponent> pr = this.factor();
        for(LargeInteger i = LargeInteger.zero; i.lessThan(pr.size()); i=i.add(1)){
            pr.get(i).exponent = (LargeFraction) pr.get(i).exponent.multiply(new LargeFraction("1/2"));
            LargeInteger expTemp = pr.get(i).exponent.intPart();
            pr.get(i).exponent = pr.get(i).exponent.fracPart();
            LargeInteger basTemp = pr.get(i).base.copy();
            while(expTemp.notEqualsTo(LargeInteger.zero)){
                if(expTemp.isOdd()){
                    result = (LargeFraction) result.multiply(basTemp);
                    if(expTemp.equals(one)) break;
                }
                basTemp = basTemp.square();
                expTemp = expTemp.longDivision(two);
            }
            if(pr.get(i).exponent.equalsTo(expTemp)){
                pr.remove(i);
                i = i.subtract(1);
            }
        }
        if(pr.size().equalsTo(LargeInteger.zero)) return result;
        else if(pr.getFirst().base.equalsTo(negativeOne)) throw new ArithmeticException("Error: To allow complex numbers, please use LargePowerMonomial");
        LargeFraction k = LargePowerMonomial.buildFromFactors(pr).base;
        LargeFraction N = LargeFraction.one;
        for(int i = 0; i < 7; i++)
            N = (LargeFraction) N.add(k.subtract(N.square()).divide(N.multiply(2)));
        return (LargeFraction) result.multiply(N);
    }
